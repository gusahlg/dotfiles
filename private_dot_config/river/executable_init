#!/bin/sh
set -eu

mod="Super"

export XDG_CURRENT_DESKTOP=river
export XDG_SESSION_TYPE=wayland
export FONT=/nix/store/msa8aj23csl6747wja4y9s0r5z5mcxv7-nerd-fonts-hack-3.4.0+3.003/share/fonts/truetype/NerdFonts/Hack/HackNerdFont-Regular.ttf

dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE

# ─── Input ───────────────────────────────────────────────────────────
riverctl keyboard-layout se

# ─── Appearance ──────────────────────────────────────────────────────
riverctl border-width 4
riverctl border-color-focused 0xC8324BCC
riverctl border-color-unfocused 0x00C89659

# ─── Core keybindings ────────────────────────────────────────────────
riverctl map normal "$mod" Q spawn rio
riverctl map normal "$mod" T spawn qutebrowser
riverctl map normal "$mod" R spawn "tofi-drun --drun-launch=true --font \"$FONT\" --height 1000 --width 500 --font-size 12"
riverctl map normal "$mod" E spawn thunar
riverctl map normal "$mod" C close
riverctl map normal "$mod" V toggle-float
riverctl map normal "$mod" D spawn "rio -e nvim ~/DOCUMENTATION.txt"

# ─── Focus / swap ────────────────────────────────────────────────────
riverctl map normal "$mod" H focus-view previous
riverctl map normal "$mod" L focus-view next
riverctl map normal "$mod" K focus-view previous
riverctl map normal "$mod" J focus-view next

riverctl map normal "$mod+Shift" H swap previous
riverctl map normal "$mod+Shift" L swap next
riverctl map normal "$mod+Shift" K swap previous
riverctl map normal "$mod+Shift" J swap next

# ─── Mouse ───────────────────────────────────────────────────────────
riverctl map-pointer normal "$mod" BTN_LEFT move-view
riverctl map-pointer normal "$mod" BTN_RIGHT resize-view

# ─── Tags (workspaces 1-10) ─────────────────────────────────────────
i=1
while [ $i -le 10 ]; do
  tag=$((1 << (i - 1)))
  key=$i
  [ "$i" -eq 10 ] && key=0
  riverctl map normal "$mod" "$key" set-focused-tags "$tag"
  riverctl map normal "$mod+Shift" "$key" set-view-tags "$tag"
  i=$((i + 1))
done

# ─── Modes ───────────────────────────────────────────────────────────
riverctl declare-mode sessions
riverctl declare-mode projects
riverctl declare-mode tile_ratio

# Easily start tmux sessoin defined with tmuxp
load_session="$HOME/.local/share/load-session"
load_dev_session="$HOME/.local/share/load-repos"

riverctl map normal "$mod" Tab enter-mode sessions
riverctl map sessions None 1 spawn "rio -e $load_dev_session repos" # This session is a dev session
riverctl map sessions None 2 spawn "rio -e $load_dev_session 1_inspect" # This session is a dev session
riverctl map sessions None 3 spawn "rio -e $load_dev_session 2_inspect" # This session is a dev session
riverctl map sessions None 4 spawn "rio -e $load_dev_session 3_inspect" # This session is a dev session
riverctl map sessions None 5 spawn "rio -e $load_dev_session 4_inspect" # This session is a dev session
riverctl map sessions None 6 spawn "rio -e $load_dev_session 5_inspect" # This session is a dev session
riverctl map sessions None 7 spawn "rio -e $load_dev_session 6_inspect" # This session is a dev session
riverctl map sessions None 8 spawn "rio -e $load_dev_session 7_inspect" # This session is a dev session
riverctl map sessions None 9 spawn "rio -e $load_dev_session 8_inspect" # This session is a dev session
riverctl map sessions None 0 spawn "rio -e $load_session config" # This is for config overview
riverctl map sessions None Escape enter-mode normal

# ─── Utilities ───────────────────────────────────────────────────────
riverctl map normal "$mod" F1 spawn "$HOME/.local/share/night-light"

if command -v grim >/dev/null 2>&1 && command -v slurp >/dev/null 2>&1; then
  riverctl map normal "$mod" Z spawn "sh -c 'mkdir -p $HOME/Pictures/Screenshots && grim -g \"\$(slurp)\" - | tee $HOME/Pictures/Screenshots/\$(date +%Y-%m-%d_%H-%M-%S).png | wl-copy'"
fi

riverctl map normal "$mod" X spawn "$HOME/.local/share/rec"
riverctl map normal "$mod+Shift" X spawn "$HOME/.local/share/rec-stop"

# ─── Media keys ──────────────────────────────────────────────────────
riverctl map normal None XF86AudioRaiseVolume spawn "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"
riverctl map normal None XF86AudioLowerVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
riverctl map normal None XF86AudioMute spawn "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
riverctl map normal None XF86AudioMicMute spawn "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"

riverctl map normal None XF86MonBrightnessUp spawn "brightnessctl -e4 -n2 set 5%+"
riverctl map normal None XF86MonBrightnessDown spawn "brightnessctl -e4 -n2 set 5%-"

riverctl map normal None XF86AudioNext spawn "playerctl next"
riverctl map normal None XF86AudioPrev spawn "playerctl previous"
riverctl map normal None XF86AudioPlay spawn "playerctl play-pause"
riverctl map normal None XF86AudioPause spawn "playerctl play-pause"

# ─── Layout ──────────────────────────────────────────────────────────
riverctl default-layout rivertile
riverctl spawn "rivertile -view-padding 0 -outer-padding 0"

riverctl map normal "$mod" B enter-mode tile_ratio
riverctl map tile_ratio "$mod" H send-layout-cmd rivertile "main-ratio -0.05"
riverctl map tile_ratio "$mod" L send-layout-cmd rivertile "main-ratio +0.05"
riverctl map tile_ratio "$mod" B enter-mode normal

# ─── Autostart ───────────────────────────────────────────────────────
riverctl spawn waybar
riverctl spawn "wl-paste --type text --watch cliphist store"
riverctl spawn "wl-paste --type image --watch cliphist store"
swaybg -i ~/Pictures/doctor_nath.png -m fill
